<?xml version="1.0" encoding="UTF-8"?>
<testSet xmlns="http://difi.no/xsd/vefa/validator/1.0"
	configuration="ehf-cv-request-1.0">
	<assert>
		<description>Verify maximum experience is larger than minimum experience</description>
		<scope>EHF-CV-REQ-R004</scope>
	</assert>

	<test id="1">
		<assert>
			<success>EHF-CV-REQ-R004</success>
		</assert>
		<CVRequest xmlns="urn:fdc:anskaffelser.no:2019:ehf:schema:CVRequest-1">

      <RequiredTotalExperience>
        <MinimumYearsExperience>3</MinimumYearsExperience>
        <MaximumYearsExperience>7</MaximumYearsExperience>
      </RequiredTotalExperience>

		</CVRequest>
	</test>

  <test id="2">
    <assert>
      <error>EHF-CV-REQ-R004</error>
    </assert>
    <CVRequest xmlns="urn:fdc:anskaffelser.no:2019:ehf:schema:CVRequest-1">

      <RequiredTotalExperience>
        <MinimumYearsExperience>7</MinimumYearsExperience>
        <MaximumYearsExperience>7</MaximumYearsExperience>
      </RequiredTotalExperience>

    </CVRequest>
  </test>

  <test id="3">
    <assert>
      <error>EHF-CV-REQ-R004</error>
    </assert>
    <CVRequest xmlns="urn:fdc:anskaffelser.no:2019:ehf:schema:CVRequest-1">

      <RequiredTotalExperience>
        <MinimumYearsExperience>10</MinimumYearsExperience>
        <MaximumYearsExperience>7</MaximumYearsExperience>
      </RequiredTotalExperience>

    </CVRequest>
  </test>

</testSet>
